{
  "name": "attendance-node-js",
  "version": "1.0.0",
  "description": "Attendance system backend in JavaScript with Express 5, Prisma, PostgreSQL",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "node --watch --env-file=.env src/server.js",
    "build": "npm install && DISABLE_ERD=true prisma generate && prisma migrate deploy && node scripts/init-admin.js",
    "start": "node src/server.js",
    "sync:summaries": "node scripts/backfill-attendance-summaries.js"
  },
  "dependencies": {
    "@prisma/client": "^6.4.0",
    "bcrypt": "^5.1.1",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "express": "^5.0.1",
    "google-auth-library": "^9.14.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.5.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "pino-pretty": "^13.0.0",
    "prisma-erd-generator": "^2.4.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "prisma": "^6.19.2"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}

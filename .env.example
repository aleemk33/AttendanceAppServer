# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://attendance_user:attendance_pass@localhost:5432/attendance_db
DIRECT_URL=postgresql://attendance_user:attendance_pass@localhost:5432/attendance_db

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-me
JWT_REFRESH_SECRET=your-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Business
BUSINESS_TIMEZONE=Asia/Kolkata
FULL_DAY_MINUTES=480
HALF_DAY_MINUTES=240
COMPANY_DOMAIN=example.com

# Google OAuth
GOOGLE_WEB_CLIENT_ID=your-web-client-id
GOOGLE_ANDROID_CLIENT_ID=your-android-client-id

# CORS
CORS_WEB_ORIGIN=http://localhost:3001

# Logging
LOG_LEVEL=info
